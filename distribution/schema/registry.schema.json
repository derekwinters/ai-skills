{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ai-skills distribution registry",
  "description": "Repo-config-as-code: bundles of installable units + per-repo config.",
  "type": "object",
  "required": ["version", "repos"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 1 },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "install_root": { "type": "string", "default": ".claude" },
        "sync_branch": { "type": "string", "default": "claude/skills-sync" }
      }
    },
    "bundles": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "skills": { "type": "array", "items": { "type": "string" } },
          "agents": { "type": "array", "items": { "type": "string" } },
          "workflows": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "repos": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["bundles"],
        "additionalProperties": false,
        "properties": {
          "bundles": { "type": "array", "items": { "type": "string" } },
          "config": { "$ref": "repo-config.schema.json" }
        }
      }
    }
  }
}
